# PostgreSQL connection (local or managed Postgres on your server)
DATABASE_URL=postgresql://user:password@localhost:5432/wedding_itinerary

# Session signing secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Free flight status API (100 requests/month) — https://aviationstack.com/signup/free
AVIATIONSTACK_ACCESS_KEY=

# AirLabs flight tracking & airport arrivals — https://airlabs.co/signup
AIRLABS_API_KEY=

# Platform operator account (role level 0). Set to an existing username after deploy.
SUPERUSER_USERNAME=

# Host port published by Docker (OpenResty/nginx proxies to this)
PORT=3102

# SCP deploy target (Diagnostics → Dump & upload). On the production server this
# path is bind-mounted to /app/seeds so restore sees uploaded dumps.
SERVER=
DEPLOY_TARGET_DIR=
DEPLOY_USERNAME=
DEPLOY_PASSWORD=
